{
  "manifest_version": 3,
  "name": "2026HarmonyOS开发者激励数据看板增强",
  "author": "黎明时候",
  "description": "2026 鸿蒙开发者激励计划达标数据看板分析插件",
  "version": "0.1.2",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://developer.huawei.com/*"],
  "action": {
    "default_title": "HarmonyOS 激励数据",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://developer.huawei.com/consumer/cn/activity/harmonyos-incentive/data-query2026*"],
      "js": ["src/injected/injected.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://developer.huawei.com/consumer/cn/activity/harmonyos-incentive/data-query2026*"],
      "js": [
        "src/content/config.js",
        "src/content/styles.js",
        "src/content/data.js",
        "src/content/mau-snapshot.js",
        "src/content/page-dom.js",
        "src/content/privacy.js",
        "src/content/filter.js",
        "src/content/table-render.js",
        "src/content/messaging.js",
        "src/content/stats-panel.js",
        "src/content/main.js"
      ],
      "run_at": "document_end"
    }
  ]
}
